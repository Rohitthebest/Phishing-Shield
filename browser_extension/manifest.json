{
  "manifest_version": 3,
  "name": "Phishing Shield Auto Checker",
  "version": "1.0.0",
  "description": "Automatically checks the current website with the local Phishing Shield app.",
  "permissions": ["tabs", "storage", "webNavigation"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Phishing Shield",
    "default_popup": "popup.html"
  }
}
